# ── UrgnanoComEra — Variabili d'ambiente ──────────────────────────────────────
# Copiare in .env.local per sviluppo locale

# Payload CMS — chiave segreta JWT (obbligatoria, cambiare in produzione!)
PAYLOAD_SECRET=cambia-questa-chiave-in-produzione

# Database
# Fase A: SQLite (default se non specificato)
DATABASE_URI=file:./data/urgnanocomera.db
# Fase B: PostgreSQL — decommentare e compilare
# DATABASE_URI=postgresql://user:password@localhost:5432/urgnanocomera

# URL pubblico del server (usato da Payload per generare URL assoluti)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Directory media (lasciare vuoto in locale → usa ./public/media servita da Next.js)
# Railway: impostare su /app/data/media (stesso volume del DB)
# PAYLOAD_MEDIA_DIR=/app/data/media

# Meilisearch (ricerca full-text archivio)
# Lasciare vuoto per disabilitare — il sito usa Payload come fallback
# MEILISEARCH_HOST=https://xxx.meilisearch.io
# MEILISEARCH_API_KEY=

# SMTP (per email contributi — opzionale in sviluppo)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@urgnanocomera.it

# Fase B — Cloudflare R2 (storage media)
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=
# CLOUDFLARE_R2_BUCKET=urgnanocomera-media
# CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
